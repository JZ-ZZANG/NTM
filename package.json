{
  "name": "nai_tag_manager",
  "version": "0.1.0",
  "description": "NAI Tag Manager with Vite + React + Electron",
  "main": "dist-electron/main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/JZ-ZZANG/NTM.git"
  },
  "type": "module",
  "scripts": {
    "dev": "chcp 65001 && (if exist dist-electron rmdir /s /q dist-electron) && vite",
    "build": "tsc && vite build",
    "dist": "npm run build && electron-builder",
    "dist:publish": "npm run build && electron-builder --publish always",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.ntm.app",
    "productName": "NTM",
    "copyright": "Copyright © 2024",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron",
      "package.json"
    ],
    "extraResources": [
      { "from": "data", "to": "data", "filter": ["**/*"] },
      { "from": "locales", "to": "locales", "filter": ["**/*"] }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "publish": [{ "provider": "github" }],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "i18next": "^23.11.5",
    "react-dropzone": "^14.2.3",
    "react-i18next": "^14.1.2",
    "react-router-dom": "^6.23.1",
    "sharp": "^0.33.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^30.0.6",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
